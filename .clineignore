# Dependencies and package manager state
/node_modules/
**/node_modules/
/vendor/
/.venv/
**/.venv/
/package-lock.json
/npm-shrinkwrap.json
/yarn.lock
/pnpm-lock.yaml

# Next.js build and static export output
/.next/
**/.next/
/out/
/_next/
/_error/
/build/
/dist/

# Test and coverage output
/coverage/

# Tool caches and generated artifacts
/.cache/
/.turbo/
/.vercel/
*.tsbuildinfo
*.map
*.min.js
*.min.css

# Agent/tool payloads that are not portfolio source context
/.agents/skills/
/.cline/skills/
/.claude/skills/
/.claude-plugin/
/.codex/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment and machine state
.env
.env.*
!.env.example
.DS_Store
/.idea/

# Large data files
*.csv
*.tsv
*.xlsx
*.xls
*.sqlite
*.sqlite3
*.db
*.parquet

# Binary media; SVGs stay visible because they are editable source text
*.png
*.PNG
*.jpg
*.JPG
*.jpeg
*.JPEG
*.gif
*.webp
*.ico
*.avif
*.mp4
*.mov
*.webm
*.mp3
*.wav
*.woff
*.woff2
*.ttf
*.otf

# Generated root-level static export artifacts
/*.html
/.nojekyll
